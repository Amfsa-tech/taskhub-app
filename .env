# Base URL of the TaskHub backend API (no trailing slash).
#   Deployed: https://task-hub-backend.onrender.com
#   Local (device on same network): http://<your-machine-lan-ip>:3009
EXPO_PUBLIC_API_URL=https://task-hub-backend.onrender.com

EXPO_PUBLIC_GEOAPIFY_API_KEY=b59812d667164bdab672a92f51428750

# Google Sign-In (native, requires a development build).
# WEB client ID: set to the SAME value as the backend's GOOGLE_CLIENT_ID (the
# OAuth *web* client ID) so the ID token's audience matches.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=865414877881-q238vncat0251fof8cq1mn4kdlfc6155.apps.googleusercontent.com
# iOS client ID: the OAuth *iOS* client from the same Google Cloud project.
# Its reversed form (com.googleusercontent.apps.XXX) is the app URL scheme set
# in app.json's google-signin plugin.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=865414877881-tihd83p5o5h386g4na6of50lbd2vdagl.apps.googleusercontent.com
