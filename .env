# Base URL of the TaskHub backend API (no trailing slash).
#   Deployed: https://task-hub-backend.onrender.com
#   Local (device on same network): http://<your-machine-lan-ip>:3009
EXPO_PUBLIC_API_URL=https://task-hub-backend.onrender.com

EXPO_PUBLIC_GEOAPIFY_API_KEY=b59812d667164bdab672a92f51428750

# Google Sign-In (native, requires a development build). Set this to the SAME
# value as the backend's GOOGLE_CLIENT_ID (the OAuth *web* client ID) so the ID
# token's audience matches. Leave blank until you configure Google Sign-In.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
